---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import { marked } from 'marked';

const allProjects = await getCollection('projects');

// Import all illustration source images for optimization
const illustrationModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/illustrations/*.{png,jpg,webp}',
  { eager: true }
);

// Build a map: filename → ImageMetadata
const illustrationMap = new Map<string, ImageMetadata>();
for (const [path, mod] of Object.entries(illustrationModules)) {
  const filename = path.split('/').pop()!;
  illustrationMap.set(filename, mod.default);
}

// Generate optimized images at 1x and 2x for card display
async function optimizeImage(imagePath: string) {
  const filename = imagePath.split('/').pop()!;
  const src = illustrationMap.get(filename);
  if (!src) return { src: imagePath, srcset: '' };

  const [img1x, img2x] = await Promise.all([
    getImage({ src, width: 400, format: 'webp' }),
    getImage({ src, width: 800, format: 'webp' }),
  ]);

  return {
    src: img1x.src,
    srcset: `${img1x.src} 400w, ${img2x.src} 800w`,
  };
}

// Sort by order, render markdown bodies at build time
const projectEntries = await Promise.all(
  allProjects
    .sort((a, b) => a.data.order - b.data.order)
    .map(async (p) => {
      const optimized = p.data.image ? await optimizeImage(p.data.image) : { src: '', srcset: '' };
      return {
        id: p.id,
        title: p.data.title,
        shortTitle: p.data.shortTitle,
        category: p.data.category,
        color: p.data.color,
        org: p.data.org,
        role: p.data.role,
        dates: p.data.dates,
        order: p.data.order,
        description: p.data.description,
        bullets: p.data.bullets,
        tags: p.data.tags ?? [p.data.category],
        stats: p.data.stats ?? [],
        image: optimized.src,
        imageSrcset: optimized.srcset,
        illoSize: p.data.illoSize ?? 0,
        body: p.body ? await marked.parse(p.body) : '',
      };
    })
);

// Intro card — replaces the toast, sits in the grid
const introCard = {
  id: '__intro__',
  title: '',
  shortTitle: '',
  category: '',
  color: 'intro',
  org: '',
  role: '',
  dates: '',
  order: -1,
  description: '',
  bullets: [],
  tags: [],
  stats: [],
  image: '',
  imageSrcset: '',
  illoSize: 0,
  body: '',
};

const projects = [...projectEntries, introCard];
---

<Base title="Hisham Saif — Portfolio">
  <!-- Header (hidden, kept for future use) -->
  <header class="header" style="display:none">
    <div class="header__name-wrap">
      <div class="header__name">Hisham Saif</div>
    </div>
    <nav class="header__nav">
      <a class="header__link" href="mailto:hisham.saif.doha@gmail.com">Contact</a>
      <a class="header__link" href="https://www.linkedin.com/in/hisham-saif-379b40153/" target="_blank" rel="noopener">LinkedIn</a>
    </nav>
  </header>

  <!-- Home button -->
  <button class="home-btn" id="home-btn" aria-label="Go home">
    <svg width="20" height="20" viewBox="0 0 32 32" fill="currentColor">
      <path d="M16.6123,2.2138a1.01,1.01,0,0,0-1.2427,0L1,13.4194l1.2427,1.5717L4,13.6209V26a2.0041,2.0041,0,0,0,2,2H26a2.0037,2.0037,0,0,0,2-2V13.63L29.7573,15,31,13.4282ZM18,26H14V18h4Zm2,0V18a2.0023,2.0023,0,0,0-2-2H14a2.002,2.002,0,0,0-2,2v8H6V12.0615l10-7.79,10,7.8005V26Z"/>
    </svg>
  </button>

  <!-- Grid viewport -->
  <div class="grid-viewport" id="grid"></div>

  <!-- Drag hint -->
  <div class="drag-hint">Drag to explore</div>

  <!-- Overlay -->
  <div class="overlay"></div>

  <!-- Sidebar -->
  <aside class="sidebar" role="dialog" aria-label="Project details">
    <div class="sidebar__header">
      <div class="sidebar__eyebrow"></div>
      <button class="sidebar__close-btn" aria-label="Close">&times;</button>
    </div>
    <div class="sidebar__color-bar"></div>
    <div class="sidebar__content">
      <h2 class="sidebar__title"></h2>
      <p class="sidebar__dates"></p>
      <div class="sidebar__hero"></div>
      <blockquote class="sidebar__description"></blockquote>
      <div class="sidebar__stats"></div>
      <h3 class="sidebar__section-title"></h3>
      <ul class="sidebar__bullets"></ul>
      <div class="sidebar__body"></div>
      <div class="sidebar__footer">
        <div class="sidebar__footer-tags"></div>
        <div class="sidebar__footer-dates"></div>
      </div>
    </div>
  </aside>

  <!-- Inject project data and boot scripts -->
  <script define:vars={{ projects }}>
    window.__PROJECTS__ = projects;
  </script>

  <script>
    import { initGrid } from '../scripts/grid';
    import { initSidebar } from '../scripts/sidebar';
    import type { ProjectData } from '../scripts/stamps';

    const projects = (window as any).__PROJECTS__ as ProjectData[];
    const viewport = document.getElementById('grid')!;

    initSidebar(() => {
      viewport.classList.remove('sidebar-open');
    });

    initGrid(viewport, projects);
  </script>
</Base>
