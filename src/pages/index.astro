---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { marked } from 'marked';

const allProjects = await getCollection('projects');

// Sort by order, render markdown bodies at build time
const projects = await Promise.all(
  allProjects
    .sort((a, b) => a.data.order - b.data.order)
    .map(async (p) => ({
      id: p.id,
      title: p.data.title,
      shortTitle: p.data.shortTitle,
      category: p.data.category,
      color: p.data.color,
      org: p.data.org,
      role: p.data.role,
      dates: p.data.dates,
      order: p.data.order,
      description: p.data.description,
      bullets: p.data.bullets,
      tags: p.data.tags ?? [p.data.category],
      stats: p.data.stats ?? [],
      image: p.data.image ?? '',
      illoSize: p.data.illoSize ?? 0,
      body: p.body ? await marked.parse(p.body) : '',
    }))
);
---

<Base title="Hisham Saif — Portfolio">
  <!-- Fixed Header -->
  <header class="header">
    <div class="header__name-wrap">
      <div class="header__name">Hisham Saif</div>
      <button class="bubble-toggle" id="bubble-toggle" aria-label="Toggle intro">
        <svg width="18" height="18" viewBox="0 0 32 32" fill="currentColor">
          <path d="M17.74,30,16,29l4-7h6a2,2,0,0,0,2-2V8a2,2,0,0,0-2-2H6A2,2,0,0,0,4,8V20a2,2,0,0,0,2,2h9v2H6a4,4,0,0,1-4-4V8A4,4,0,0,1,6,4H26a4,4,0,0,1,4,4V20a4,4,0,0,1-4,4H21.16Z"/>
          <rect x="8" y="10" width="16" height="2"/>
          <rect x="8" y="16" width="10" height="2"/>
        </svg>
      </button>
      <!-- Speech bubble anchored to name-wrap -->
      <div class="speech-bubble" id="speech-bubble">
        Hi, I'm a media producer &amp; project manager — and I'm open to new opportunities. Drag to explore my work.
      </div>
    </div>
    <nav class="header__nav">
      <a class="header__link" href="mailto:hisham.saif.doha@gmail.com">Contact</a>
      <a class="header__link" href="https://www.linkedin.com/in/hisham-saif-379b40153/" target="_blank" rel="noopener">LinkedIn</a>
    </nav>
  </header>

  <!-- Grid viewport -->
  <div class="grid-viewport" id="grid"></div>

  <!-- Drag hint -->
  <div class="drag-hint">Drag to explore</div>

  <!-- Overlay -->
  <div class="overlay"></div>

  <!-- Sidebar -->
  <aside class="sidebar" role="dialog" aria-label="Project details">
    <div class="sidebar__header">
      <div class="sidebar__eyebrow"></div>
      <button class="sidebar__close-btn" aria-label="Close">&times;</button>
    </div>
    <div class="sidebar__color-bar"></div>
    <div class="sidebar__content">
      <h2 class="sidebar__title"></h2>
      <p class="sidebar__dates"></p>
      <div class="sidebar__hero"></div>
      <blockquote class="sidebar__description"></blockquote>
      <div class="sidebar__stats"></div>
      <h3 class="sidebar__section-title"></h3>
      <ul class="sidebar__bullets"></ul>
      <div class="sidebar__body"></div>
      <div class="sidebar__footer">
        <div class="sidebar__footer-tags"></div>
        <div class="sidebar__footer-dates"></div>
      </div>
    </div>
  </aside>

  <!-- Inject project data and boot scripts -->
  <script define:vars={{ projects }}>
    window.__PROJECTS__ = projects;
  </script>

  <script>
    import { initGrid } from '../scripts/grid';
    import { initSidebar } from '../scripts/sidebar';
    import type { ProjectData } from '../scripts/stamps';

    const projects = (window as any).__PROJECTS__ as ProjectData[];
    const viewport = document.getElementById('grid')!;

    initSidebar(() => {
      viewport.classList.remove('sidebar-open');
    });

    initGrid(viewport, projects);

    // Speech bubble toggle
    const bubble = document.getElementById('speech-bubble')!;
    const toggle = document.getElementById('bubble-toggle')!;

    const isHidden = () => bubble.classList.contains('hidden');

    const hideBubble = () => {
      bubble.classList.remove('animate-in');
      bubble.classList.add('hidden');
      toggle.classList.remove('active');
      localStorage.setItem('bubble-dismissed', '1');
    };

    const showBubble = () => {
      bubble.classList.remove('hidden');
      bubble.classList.add('animate-in');
      toggle.classList.add('active');
      localStorage.removeItem('bubble-dismissed');
    };

    // Restore state from localStorage
    if (localStorage.getItem('bubble-dismissed')) {
      bubble.classList.add('hidden');
    } else {
      bubble.classList.add('animate-in');
      toggle.classList.add('active');
    }

    // Toggle icon opens/closes
    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      isHidden() ? showBubble() : hideBubble();
    });

    // Click anywhere on bubble to dismiss
    bubble.addEventListener('click', (e) => {
      e.stopPropagation();
      hideBubble();
    });
  </script>
</Base>
